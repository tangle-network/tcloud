{
  "name": "@tangle-network/tcloud-attestation",
  "version": "0.1.1",
  "description": "Fail-closed attestation parsing and policy checks for Tangle TEE sandboxes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "check-types": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}

{
  "name": "@tangle-network/tcloud-agent",
  "version": "0.3.0",
  "description": "Agent run-loop primitive + Pi extension for Tangle AI Cloud",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "pi-package"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "pi": {
    "extensions": [
      "./src/pi-extension.ts"
    ]
  },
  "scripts": {
    "build": "tsup src/index.ts src/pi-extension.ts --format esm --clean",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "@tangle-network/sandbox": "^0.0.3",
    "@tangle-network/tcloud": "workspace:*",
    "viem": "^2.48.4"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT"
}

{
  "name": "@tangle-network/tcloud",
  "version": "0.1.3",
  "description": "TypeScript SDK and CLI for Tangle AI Cloud — decentralized LLM inference",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tcloud": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./shielded": {
      "import": {
        "types": "./dist/shielded.d.ts",
        "default": "./dist/shielded.js"
      },
      "require": {
        "types": "./dist/shielded.d.cts",
        "default": "./dist/shielded.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/shielded.ts --format esm,cjs --dts --clean --external socks-proxy-agent",
    "docs": "typedoc src/index.ts --out docs --name tcloud --readme README.md",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "commander": "^13.0.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tangle-network/tcloud.git",
    "directory": "packages/tcloud"
  },
  "homepage": "https://docs.tangleai.cloud",
  "keywords": [
    "tangle",
    "ai",
    "llm",
    "inference",
    "decentralized",
    "openai",
    "sdk",
    "cli",
    "privacy",
    "shielded-credits"
  ],
  "engines": {
    "node": ">=18"
  }
}

{
  "name": "tcloud",
  "version": "0.1.0",
  "description": "Tangle AI Cloud -- SDK + CLI for decentralized AI inference with optional privacy",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tcloud": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./shielded": {
      "import": "./dist/shielded.js",
      "types": "./dist/shielded.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/shielded.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "commander": "^13.0.0",
    "openai": "^4.0.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}

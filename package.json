{
  "name": "tcloud-monorepo",
  "private": true,
  "type": "module",
  "description": "TypeScript SDK, CLI, agent, and relayer for Tangle AI Cloud",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter tcloud dev",
    "dev:relayer": "pnpm --filter tcloud-relayer dev"
  },
  "pnpm": {
    "overrides": {
      "basic-ftp": "5.3.0",
      "fast-xml-parser": "5.7.0",
      "postcss": "8.5.10",
      "protobufjs": "7.5.5",
      "vite": "8.0.5"
    }
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
